{
  "dashboard": {
    "title": "Investor OS - HRM Performance",
    "tags": ["hrm", "investor-os"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "HRM Inference Rate (req/s)",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(hrm_inference_total[5m])",
            "legendFormat": "Inferences/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "Inference Latency (p99)",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, hrm_inference_duration_seconds_bucket)",
            "legendFormat": "p99 Latency"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 3,
        "title": "Inference Latency Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "hrm_inference_duration_seconds_bucket",
            "format": "heatmap"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
        "options": {
          "calculate": false
        }
      },
      {
        "id": 4,
        "title": "Active WebSocket Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "websocket_connections_active",
            "legendFormat": "Connections"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "options": {
          "colorMode": "value"
        }
      },
      {
        "id": 5,
        "title": "WebSocket Messages (per minute)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(websocket_messages_total[1m])",
            "legendFormat": "{{direction}} - {{message_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 16}
      },
      {
        "id": 6,
        "title": "HRM Errors",
        "type": "stat",
        "targets": [
          {
            "expr": "hrm_inference_errors_total",
            "legendFormat": "Errors"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "API Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(api_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 24}
      },
      {
        "id": 8,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "Memory"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 9,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m])",
            "legendFormat": "CPU"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      }
    ]
  }
}
