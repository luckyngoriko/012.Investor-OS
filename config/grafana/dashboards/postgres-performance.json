{
  "dashboard": {
    "title": "PostgreSQL Performance - Sprint 5",
    "tags": ["sprint-5", "postgres", "performance"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Slow Queries (Top 10)",
        "type": "table",
        "targets": [
          {
            "expr": "SELECT query, calls, mean_exec_time, total_exec_time FROM pg_stat_statements ORDER BY mean_exec_time DESC LIMIT 10",
            "format": "table",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "mean_exec_time"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "gradient-gauge"
                },
                {
                  "id": "thresholds",
                  "value": {
                    "steps": [
                      {"value": 0, "color": "green"},
                      {"value": 100, "color": "yellow"},
                      {"value": 1000, "color": "red"}
                    ]
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 2,
        "title": "Query Execution Time Trend",
        "type": "timeseries",
        "targets": [
          {
            "expr": "SELECT time_bucket('5 minutes', timestamp) as time, AVG(mean_exec_time) FROM pg_stat_statements GROUP BY time ORDER BY time",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0
          }
        }
      },
      {
        "id": 3,
        "title": "Cache Hit Ratio",
        "type": "stat",
        "targets": [
          {
            "expr": "SELECT 100.0 * sum(heap_blks_hit) / (sum(heap_blks_hit) + sum(heap_blks_read)) as ratio FROM pg_statio_user_tables",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 95, "color": "yellow"},
                {"value": 99, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "SELECT count(*) FROM pg_stat_activity WHERE state = 'active'",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8}
      },
      {
        "id": 5,
        "title": "Table Sizes",
        "type": "bargauge",
        "targets": [
          {
            "expr": "SELECT tablename, pg_total_relation_size(schemaname||'.'||tablename) as size FROM pg_tables WHERE schemaname = 'public' ORDER BY size DESC LIMIT 20",
            "format": "table",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
      },
      {
        "id": 6,
        "title": "Index Usage",
        "type": "table",
        "targets": [
          {
            "expr": "SELECT schemaname, tablename, indexrelname, idx_scan, idx_tup_read FROM pg_stat_user_indexes ORDER BY idx_scan DESC LIMIT 20",
            "format": "table",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 7,
        "title": "TimescaleDB Compression Ratio",
        "type": "stat",
        "targets": [
          {
            "expr": "SELECT avg(compression_ratio) FROM timescaledb_information.compressed_chunk_stats",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 20},
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.8, "color": "yellow"},
                {"value": 0.9, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Materialized View Refresh Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "SELECT time, duration_ms FROM mv_refresh_log ORDER BY time",
            "datasource": "PostgreSQL"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 18, "y": 20}
      }
    ]
  }
}
