# Investor OS - Environment Configuration

# Database Configuration
DB_USER=investor
DB_PASSWORD=investor123
DB_NAME=investor_os
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Configuration
API_PORT=3000
RUST_LOG=info

# Grafana Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# External API Keys (optional for basic operation)
FINNHUB_API_KEY=your_finnhub_api_key
ALPHAVANTAGE_API_KEY=your_alphavantage_key

# Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Anti-Fake Security Shield
# Set to true in production after client integration is complete.
ANTI_FAKE_ENFORCE=false
ANTI_FAKE_REQUIRE_SIGNATURE_FOR_WRITES=false
# Enforce real (non-demo) data in strict mode.
ANTI_FAKE_ENFORCE_FAKE_DATA=false
# Allow explicitly listed demo/synthetic endpoints while strict mode is on.
ANTI_FAKE_ALLOW_DEMO_ENDPOINTS=false
# Comma-separated path prefixes considered synthetic/demo content.
ANTI_FAKE_FAKE_ENDPOINT_PREFIXES=/api/demo
ANTI_FAKE_HMAC_SECRET=change_me_to_long_random_secret
ANTI_FAKE_MAX_TIMESTAMP_SKEW_SECS=90
ANTI_FAKE_NONCE_TTL_SECS=300
ANTI_FAKE_SESSION_BINDING_TTL_SECS=604800
ANTI_FAKE_MAX_SESSION_BINDINGS=100000
ANTI_FAKE_MIN_NONCE_LEN=8
ANTI_FAKE_MAX_NONCE_LEN=128
ANTI_FAKE_MAX_SIGNATURE_LEN=256
ANTI_FAKE_MAX_RPM=120
ANTI_FAKE_MAX_FAILED_LOGINS_PER_MIN=5
# Only set true when running behind a trusted reverse proxy that sanitizes these headers.
ANTI_FAKE_TRUST_PROXY_HEADERS=false
