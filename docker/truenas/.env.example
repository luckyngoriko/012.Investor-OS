# Investor OS — TrueNAS Environment Configuration
# Copy to /mnt/MainPool/appsdata/investor-os.net/config/.env

# --- Database ---
DB_USER=investor
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=investor_os

# --- Auth ---
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET

# --- Environment ---
INVESTOR_ENV=production
RUST_LOG=info

# --- Trading ---
PAPER_TRADING=true

# --- WebSocket Streaming ---
WS_ENABLED=true
WS_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://192.168.1.123:8080
